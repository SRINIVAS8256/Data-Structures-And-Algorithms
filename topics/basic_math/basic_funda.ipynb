   "source": [
    "# reverse the string\n",
    "ascii=[]\n",
    "string=\"srinivas\"\n",
    "def r(string):\n",
    "    for i in range(len(string)-1,-1,-1):\n",
    "        ascii.append(string[i])\n",
    "    return ''.join(ascii)\n",
    "r(string)\n"
   ]
