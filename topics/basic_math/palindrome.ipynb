   "source": [
    "def palindrome(num):\n",
    "    temp=num\n",
    "    ans=0\n",
    "    while(num>0):\n",
    "        rem=num%10\n",
    "        ans=ans*10 + rem\n",
    "        num=num//10\n",
    "    if temp == ans:\n",
    "        return \"palindrome\"\n",
    "    else:\n",
    "        return \"not palindrome\"\n",
    "palindrome(1310)"
   ]
